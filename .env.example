# Copy this file to ".env" and fill in real values. (.env is gitignored — never commit real keys.)
# Your previous .env was lost when OneDrive corrupted the old folder; re-enter the values below.

# ── Supabase (Project Settings → API) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only — do NOT prefix with VITE_ (keep out of the client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Gemini (AI assistant "Aleza") ──
# Server-side key used by the Netlify proxy (netlify/functions/gemini-plan.js)
GEMINI_API_KEY=
# Optional client-side key (only if you want the browser to call Gemini directly)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash
VITE_GEMINI_FALLBACK_MODELS=gemini-1.5-flash,gemini-1.5-pro

# ── Optional: licensed MCA company-data provider (CIN auto-fill on Create Company) ──
VITE_MCA_API_URL=
VITE_MCA_API_KEY=
